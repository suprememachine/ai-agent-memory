# ============================================================
# LLM PROVIDER — pilih salah satu: gemini | qwen | openai | custom
# ============================================================
LLM_PROVIDER=gemini

# ── Gemini (Google) ──────────────────────────────────────────
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxx

# Model Gemini yang tersedia:
#   gemini-2.0-flash       → Recommended (cepat, murah, pintar)
#   gemini-2.0-flash-lite  → Paling cepat & murah
#   gemini-1.5-pro         → Kualitas terbaik, lebih lambat
#   gemini-1.5-flash       → Seimbang

# ── Alibaba Cloud Qwen ───────────────────────────────────────
# Dapatkan di: https://dashscope.console.aliyun.com/apiKey
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Model Qwen: qwen-plus | qwen-max | qwen-turbo | qwen-long

# ── OpenAI ───────────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Model OpenAI: gpt-4o | gpt-4o-mini | gpt-4-turbo

# ── Custom (Ollama, LM Studio, dsb) ─────────────────────────
# CUSTOM_API_KEY=any-key
# CUSTOM_BASE_URL=http://localhost:11434/v1

# ── Model name (override default provider model) ────────────
MODEL_NAME=gemini-2.0-flash

# ============================================================
# TELEGRAM BOT
# ============================================================
# Buat bot di @BotFather → /newbot → salin token
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIjKlMnOpQrStUvWxYz

# ID Telegram kamu → cek via @userinfobot
TELEGRAM_OWNER_ID=123456789

# ============================================================
# GITHUB MEMORY STORAGE
# ============================================================
# Token: https://github.com/settings/tokens → Classic → centang: repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=ai-agent-memory
GITHUB_BRANCH=main
MEMORY_PATH=memory

# ============================================================
# SERVER (Railway set PORT otomatis)
# ============================================================
PORT=3000
